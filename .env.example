# ========== Required ==========
PRIVATE_KEY=0x...                    # Your wallet private key (required for trading)
TELEGRAM_BOT_TOKEN=                  # From @BotFather (required for TG bot)
MONGO_URI=                           # MongoDB connection string (required for TG bot)

# ========== API ==========
GAMMA_API_BASE_URL=
CLOB_API_HOST=
CLOB_API_BASE=
CLOB_WS_URL=

# ========== Blockchain ==========
CHAIN_ID=137                         # 137 = Polygon mainnet, 80001 = Mumbai testnet
SIGNATURE_TYPE=2
FUNDER=0x...                         # Optional: funder address (default: derived from private key)

# ========== Trading ==========
ORDER_PRICE=0.47
ORDER_SIZE=5
ORDER_TYPE=LIMIT
MARKET_INTERVAL_SECONDS=300
MARKET_SLUG_PREFIX=btc-updown-5m
RISK_STOP_TIME=30

# ========== RPC & Data ==========
POLYGON_RPC=                         # e.g.  or Infura/Alchemy URL
GET_POSITION_URL=


BUILDER_SECRET=
BUILDER_PASS_PHRASE=
# Or use POLYBOT5M_EXECUTION__BUILDER_* for TG bot:
# POLYBOT5M_EXECUTION__BUILDER_API_KEY=
# POLYBOT5M_EXECUTION__BUILDER_API_SECRET=
# POLYBOT5M_EXECUTION__BUILDER_API_PASSPHRASE=


# ========== Logging ==========
LOG_LEVEL=INFO
# LOG_FILE=bot.log
